{
  "manifest_version": 3,
  "name": "AI 会话导出工具",
  "version": "1.0.0",
  "description": "从 AI 会话网页中导出内容为 Markdown 格式，支持 ChatGPT、Claude 等平台",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://*.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI 会话导出工具"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://*.anthropic.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "html-to-markdown.js", "exporter.js"],
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://*.anthropic.com/*"
      ]
    }
  ]
}
